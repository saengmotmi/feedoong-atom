{
  "name": "feedoong-atom",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend/packages/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @feedoong/web dev",
    "dev:web:edge": "yarn workspace @feedoong/web dev:edge",
    "dev:api": "yarn workspace @feedoong/api dev",
    "dev:scheduler": "yarn workspace @feedoong/scheduler dev",
    "dev:local": "./scripts/dev-local.sh",
    "smoke:local": "./scripts/smoke-local.sh",
    "smoke:worker-runtime": "bash ./scripts/smoke-api-worker-runtime.sh",
    "smoke:remote": "bash ./scripts/smoke-remote-api.sh",
    "check:slo": "node ./scripts/check-slo.mjs",
    "backup:d1": "bash ./scripts/d1-backup.sh",
    "check:architecture": "./scripts/check-architecture.sh",
    "import:subscriptions": "node ./scripts/import-subscriptions.mjs",
    "test:backend": "yarn workspace @feedoong/contracts test && yarn workspace @feedoong/rss-parser test && yarn workspace @feedoong/sync-core test && yarn workspace @feedoong/api-worker test && yarn workspace @feedoong/api test && yarn workspace @feedoong/scheduler test",
    "build": "yarn workspaces foreach -Apt run build",
    "typecheck": "yarn workspaces foreach -Apt run typecheck && yarn check:architecture"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "yarn@4.12.0",
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
